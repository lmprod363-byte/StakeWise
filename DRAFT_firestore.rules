rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PHASE 4: Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['total', 'unitSize', 'updatedAt']) &&
             data.total is number &&
             data.unitSize is number &&
             data.updatedAt is timestamp;
    }

    function isValidBankroll(data) {
      return data.keys().hasAll(['name', 'total', 'unitSize', 'userId', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.total is number &&
             data.unitSize is number &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidBet(data) {
      let requiredKeys = ['userId', 'bankrollId', 'date', 'sport', 'event', 'market', 'selection', 'odds', 'stake', 'status', 'profit', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredKeys) &&
             data.userId == request.auth.uid &&
             isValidId(data.bankrollId) &&
             data.sport is string && data.sport.size() <= 64 &&
             data.event is string && data.event.size() <= 128 &&
             data.odds is number && data.odds > 0 &&
             data.stake is number && data.stake >= 0 &&
             data.status in ['pending', 'won', 'lost', 'void', 'cashout', 'half_win', 'half_loss'] &&
             data.profit is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidTransaction(data) {
      let requiredKeys = ['userId', 'bankrollId', 'date', 'amount', 'type', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredKeys) &&
             data.userId == request.auth.uid &&
             isValidId(data.bankrollId) &&
             data.amount is number &&
             data.type in ['withdrawal', 'deposit', 'transfer', 'adjustment'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // --- PHASE 4: match Blocks ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time;
    }

    // Bankrolls
    match /bankrolls/{bankrollId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified() && isValidId(bankrollId) && isValidBankroll(incoming()) && 
                    incoming().createdAt == request.time && incoming().updatedAt == request.time;
      
      allow update: if isVerified() && isOwner(existing().userId) && isValidBankroll(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      
      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // Bets
    match /bets/{betId} {
      // Helper for relational check: Verify user owns the bankroll
      function userOwnsBankroll(bankrollId) {
        return get(/databases/$(database)/documents/bankrolls/$(bankrollId)).data.userId == request.auth.uid;
      }

      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isVerified() && isValidId(betId) && isValidBet(incoming()) &&
                    userOwnsBankroll(incoming().bankrollId) &&
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time;

      allow update: if isVerified() && isOwner(existing().userId) && isValidBet(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().bankrollId == existing().bankrollId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;

      allow delete: if isVerified() && isOwner(existing().userId);
    }

    // Transactions
    match /transactions/{transactionId} {
      function userOwnsBankroll(bankrollId) {
        return get(/databases/$(database)/documents/bankrolls/$(bankrollId)).data.userId == request.auth.uid;
      }

      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isVerified() && isValidId(transactionId) && isValidTransaction(incoming()) &&
                    userOwnsBankroll(incoming().bankrollId) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;

      allow update: if isVerified() && isOwner(existing().userId) && isValidTransaction(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().bankrollId == existing().bankrollId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;

      allow delete: if isVerified() && isOwner(existing().userId);
    }
  }
}
