{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User configuration and bankroll settings",
      "type": "object",
      "properties": {
        "total": { "type": "number", "description": "Legacy total bankroll value" },
        "unitSize": { "type": "number", "description": "Legacy standard unit size" },
        "geminiKey": { "type": "string", "description": "Stored Gemini API Key" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["updatedAt"]
    },
    "Bet": {
      "title": "Bet Record",
      "description": "A single sports bet record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns this bet" },
        "bankrollId": { "type": "string", "description": "The ID of the bankroll this bet belongs to" },
        "date": { "type": "string", "format": "date-time" },
        "sport": { "type": "string" },
        "event": { "type": "string" },
        "market": { "type": "string" },
        "selection": { "type": "string" },
        "odds": { "type": "number" },
        "stake": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost", "void", "cashout", "half_win", "half_loss"] },
        "profit": { "type": "number" },
        "bookmaker": { "type": "string" },
        "cashoutValue": { "type": "number" },
        "notes": { "type": "string" },
        "deleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bankrollId", "date", "sport", "event", "market", "selection", "odds", "stake", "status", "profit"]
    },
    "Bankroll": {
      "title": "Bankroll Profile",
      "description": "Individual bankroll configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "total": { "type": "number" },
        "unitSize": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "total", "unitSize", "userId"]
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "Withdrawals, deposits or transfers between bookmakers",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bankrollId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["withdrawal", "deposit", "transfer"] },
        "fromBookmaker": { "type": "string" },
        "toBookmaker": { "type": "string" },
        "notes": { "type": "string" },
        "deleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "bankrollId", "date", "amount", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores legacy user settings"
    },
    "/bankrolls/{bankrollId}": {
      "schema": "Bankroll",
      "description": "Stores individual bankroll configurations"
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "Stores individual bet records with owner UID"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Stores bankroll transactions: withdrawals, deposits, transfers"
    }
  }
}
